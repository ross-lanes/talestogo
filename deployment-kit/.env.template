# =============================================================================
# Tales Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# Generate secure random keys with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Security Keys
# -----------------------------------------------------------------------------
# Generate unique values for your deployment (see command above)

JWT_SECRET_KEY=CHANGE_ME_generate_a_random_key
ENCRYPTION_KEY=CHANGE_ME_generate_a_random_key

# -----------------------------------------------------------------------------
# REQUIRED: LLM API Keys (at least ONE)
# -----------------------------------------------------------------------------
# You need at least one LLM provider. Gemini is recommended (cheapest).
# Only providers with API keys configured will be available.

# Google Gemini (RECOMMENDED - cheapest, supports analysis + web search)
# Get key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI / ChatGPT (optional)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic / Claude (optional)
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Perplexity (optional - supports web search)
# Get key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL: OAuth Configuration
# -----------------------------------------------------------------------------
# Email/password authentication works without these.
# Add OAuth credentials if you want "Sign in with Google/Microsoft" buttons.

# Google OAuth (optional)
# Get credentials: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (optional)
# Get credentials: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# OPTIONAL: Email Configuration (for sending invitations)
# -----------------------------------------------------------------------------
# Without this, you'll need to share credentials manually with new users.

# Resend (recommended for hosted deployments)
# Get key: https://resend.com
RESEND_API_KEY=
FROM_EMAIL=admin@yourdomain.com

# -----------------------------------------------------------------------------
# OPTIONAL: Database Configuration
# -----------------------------------------------------------------------------
# By default, Tales uses SQLite (no configuration needed).
# For production with multiple users, PostgreSQL is recommended.

# PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@host:5432/tales_db

# -----------------------------------------------------------------------------
# OPTIONAL: Performance Configuration
# -----------------------------------------------------------------------------

# Redis for caching (improves performance)
# REDIS_URL=redis://localhost:6379

# Application environment
ENVIRONMENT=production

# Frontend URL (for CORS, set to your actual domain)
FRONTEND_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# OPTIONAL: Scheduler Configuration
# -----------------------------------------------------------------------------
# Enable automated data collection and report generation
# Collection runs on 1st, 7th, 14th, 21st of each month
# Reports generated monthly, quarterly, and annually

ENABLE_SCHEDULER=true
