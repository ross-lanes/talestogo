# =============================================================================
# Tales Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# Documentation: See IT_DEPLOYMENT_GUIDE.md
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Security Keys
# -----------------------------------------------------------------------------
# Generate secure random keys for production:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# Secret key for JWT signing
APP_SECRET=CHANGE_ME_generate_a_random_key

# ENCRYPTION_KEY is used for encrypting stored API keys
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_generate_a_fernet_key

# Database password
DB_PASSWORD=tales_password

# -----------------------------------------------------------------------------
# OPTIONAL: OIDC Configuration (Microsoft Entra ID)
# -----------------------------------------------------------------------------
# Only needed if using Microsoft/Entra ID login (ENABLE_MICROSOFT_AUTH=true)
# IT will provide these values during app registration

# Azure AD / Entra ID Application Client ID
OIDC_CLIENT_ID=

# Azure AD / Entra ID Application Client Secret
OIDC_CLIENT_SECRET=

# OIDC Discovery URL (optional - for tenant-specific configurations)
# Default: https://login.microsoftonline.com/common/v2.0/.well-known/openid-configuration
# For single-tenant: https://login.microsoftonline.com/{tenant-id}/v2.0/.well-known/openid-configuration
# OIDC_DISCOVERY_URL=

# -----------------------------------------------------------------------------
# Authentication Method Flags
# -----------------------------------------------------------------------------
# Enable or disable specific authentication methods.
# The login page dynamically shows only enabled + configured methods.
# Email/password works immediately. OAuth methods also need client IDs above.

ENABLE_LOCAL_AUTH=true
ENABLE_MICROSOFT_AUTH=true
ENABLE_GOOGLE_AUTH=false

# -----------------------------------------------------------------------------
# REQUIRED: LLM API Keys (at least ONE)
# -----------------------------------------------------------------------------
# Set the env var(s) for whichever LLM providers you want to use. Then go to
# Admin → LLM Providers in the UI and enable them; the one flagged
# use_for_analysis=True handles response analysis and brand auto-generation.
#
# The "State of the LLMs" report section needs a provider with web search
# (Gemini or Perplexity). If neither is configured the section is omitted.

# Google Gemini - https://ai.google.dev/
GEMINI_API_KEY=

# OpenAI ChatGPT - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude - https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Perplexity - https://www.perplexity.ai/settings/api  (supports web search)
PERPLEXITY_API_KEY=

# Azure OpenAI - resource URL, api_version, and deployment name are configured
# per-provider in the Admin UI (they're tenant-specific). This env var only
# holds the API key. Get it from Azure Portal → your OpenAI resource → Keys.
AZURE_OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL: Bing web search (only affects the "State of the LLMs" report section)
# -----------------------------------------------------------------------------
# Tales runs fine without Bing — the State of the LLMs section is gracefully
# omitted when no web-search provider is configured. Set one of the keys
# below only if you want that section AND your deployment doesn't already
# have Gemini or Perplexity configured for it.

# Bing Search v7 — Microsoft REST API. Bing v7 retrieves search results;
# synthesis is done by whichever provider you flag use_for_analysis=True
# (e.g., Azure OpenAI). The Bing endpoint is configured in the Admin UI.
BING_SEARCH_V7_API_KEY=

# Azure AI Foundry "Grounding with Bing Search" — single-vendor Azure
# story. Requires `pip install talestogo[bing-grounded]` server-side.
# Project endpoint + api_version + agent ID are configured in the Admin UI.
AZURE_FOUNDRY_API_KEY=

# -----------------------------------------------------------------------------
# Branding (Customize for Your Organization)
# -----------------------------------------------------------------------------

# Site name displayed in the UI
SITE_NAME=Tales

# URL to your organization's logo (optional)
# SITE_LOGO_URL=https://your-org.gov/logo.png

# Theme colors (hex format)
SITE_PRIMARY_COLOR=#003e60
SITE_SECONDARY_COLOR=#75c9c8

# -----------------------------------------------------------------------------
# OPTIONAL: Google OAuth
# -----------------------------------------------------------------------------
# Only needed if ENABLE_GOOGLE_AUTH=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# OPTIONAL: Email Configuration
# -----------------------------------------------------------------------------
# For sending user invitation emails

# Resend API (https://resend.com)
RESEND_API_KEY=
FROM_EMAIL=admin@yourdomain.gov

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Frontend URL for CORS and email links
FRONTEND_URL=http://localhost:8080

# Port mapping (change if 8080 is in use)
APP_PORT=8080

# Environment mode
ENVIRONMENT=production

# Enable automated data collection and report generation
ENABLE_SCHEDULER=true
