# =============================================================================
# Tales Environment Configuration (PPPL-Compliant)
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# Documentation: See docs/ENV_VARS_REFERENCE.md
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Security Keys
# -----------------------------------------------------------------------------
# Generate secure random keys for production:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# APP_SECRET is the PPPL standard name for JWT signing
# (JWT_SECRET_KEY also works for backwards compatibility)
APP_SECRET=CHANGE_ME_generate_a_random_key

# ENCRYPTION_KEY is used for encrypting stored API keys
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_generate_a_fernet_key

# Database password
DB_PASSWORD=tales_password

# -----------------------------------------------------------------------------
# REQUIRED: OIDC Configuration (Microsoft Entra ID)
# -----------------------------------------------------------------------------
# IT will provide these values during deployment registration
# OIDC_* is the PPPL standard naming convention

# Azure AD / Entra ID Application Client ID
OIDC_CLIENT_ID=

# Azure AD / Entra ID Application Client Secret
OIDC_CLIENT_SECRET=

# OIDC Discovery URL (optional - for tenant-specific configurations)
# Default: https://login.microsoftonline.com/common/v2.0/.well-known/openid-configuration
# For single-tenant: https://login.microsoftonline.com/{tenant-id}/v2.0/.well-known/openid-configuration
# OIDC_DISCOVERY_URL=

# -----------------------------------------------------------------------------
# Authentication Method Flags
# -----------------------------------------------------------------------------
# Enable or disable specific authentication methods
# Default: Microsoft enabled, Google disabled, local enabled

ENABLE_LOCAL_AUTH=true
ENABLE_MICROSOFT_AUTH=true
ENABLE_GOOGLE_AUTH=false

# -----------------------------------------------------------------------------
# REQUIRED: LLM API Keys (at least ONE)
# -----------------------------------------------------------------------------
# At minimum, GEMINI_API_KEY is required for response analysis
# Other keys are optional and enable querying those platforms

# Google Gemini - REQUIRED for analysis (most cost-effective)
# Get key at: https://ai.google.dev/
GEMINI_API_KEY=

# OpenAI ChatGPT - Optional for data collection
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude - Optional for data collection
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Perplexity - Optional for data collection (supports web search)
# Get key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# -----------------------------------------------------------------------------
# Branding (Lab-Specific Customization)
# -----------------------------------------------------------------------------
# Customize the appearance for your organization

# Site name displayed in the UI
SITE_NAME=Tales

# URL to your organization's logo (optional)
# SITE_LOGO_URL=https://your-lab.gov/logo.png

# Theme colors (hex format)
SITE_PRIMARY_COLOR=#003e60
SITE_SECONDARY_COLOR=#75c9c8

# -----------------------------------------------------------------------------
# OPTIONAL: Google OAuth
# -----------------------------------------------------------------------------
# Only needed if ENABLE_GOOGLE_AUTH=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# OPTIONAL: Email Configuration
# -----------------------------------------------------------------------------
# For sending user invitation emails

# Resend API (https://resend.com)
RESEND_API_KEY=
FROM_EMAIL=admin@yourdomain.gov

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Frontend URL for CORS and email links
FRONTEND_URL=http://localhost:8080

# Port mapping (change if 8080 is in use)
APP_PORT=8080

# Environment mode
ENVIRONMENT=production

# Enable automated data collection and report generation
ENABLE_SCHEDULER=true

# -----------------------------------------------------------------------------
# Legacy Variable Names (For Backwards Compatibility)
# -----------------------------------------------------------------------------
# These are supported but PPPL standard names are preferred:
#   APP_SECRET -> preferred over JWT_SECRET_KEY
#   OIDC_CLIENT_ID -> preferred over MICROSOFT_CLIENT_ID or ENTRA_CLIENT_ID
#   OIDC_CLIENT_SECRET -> preferred over MICROSOFT_CLIENT_SECRET or ENTRA_SECRET_KEY
